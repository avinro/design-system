  "anatomy": [
    {
      "part": "container",
      "description": "Card surface. Background: surface/neutral/raised. Border radius: 24px. Padding: 16px top/bottom, 16px left, 12px right.",
      "required": true
    },
    {
      "part": "image",
      "description": "128×128px venue or offering photo. Optional. In sold-out state, a 40% white overlay dims the image.",
      "required": false
    },
    {
      "part": "col",
      "description": "Content column. Flex column, fills remaining width.",
      "required": true,
      "subParts": [
        {
          "part": "col.top",
          "description": "Title, optional booking-method badge (Instant or Limited), and description text.",
          "required": true
        },
        {
          "part": "col.pills",
          "description": "Row of 0–2 badge pills. Slot 1: booking type badge (Instant, Limited, All day). Slot 2: availability/duration badge (2 left, All day, Sold out).",
          "required": false
        },
        {
          "part": "col.bottom",
          "description": "Price display (left) and guest count (right). Always shown.",
          "required": true
        }
      ]
    }
  ],

  "variantAxes": [
    {
      "name": "booking",
      "type": "VARIANT",
      "values": ["free-instant", "request-quote", "request-min-spend", "instant-fixed", "all-day-instant"],
      "defaultValue": "free-instant",
      "description": "Controls the booking flow and payment model displayed on the card."
    },
    {
      "name": "state",
      "type": "VARIANT",
      "values": ["available", "limited", "sold-out"],
      "defaultValue": "available",
      "description": "Controls the current availability state of the offering."
    }
  ],

